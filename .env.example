# Copy this file to .env and fill in the keys for the providers you use.
# cp .env.example .env

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

ASR_PROVIDER=deepgram
LLM_PROVIDER=gemini
TTS_PROVIDER=cartesia

DEEPGRAM_API_KEY=
GEMINI_API_KEY=
CARTESIA_API_KEY=

# Optional Langfuse tracing (issue #18). Requires public + secret keys.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
